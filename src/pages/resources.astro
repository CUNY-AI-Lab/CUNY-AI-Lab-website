---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;
const jsonPath = path.join(process.cwd(), 'src/data/resources.json');
const data = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));
---

<BaseLayout title="Resources - CUNY AI Lab">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-10 lg:pt-28 lg:pb-12">
    <div class="absolute inset-0 bg-gradient-to-b from-cuny-blue via-cuny-blue to-vibrant-900"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-white tracking-tight">{data.title}</h1>
      <p class="mt-4 text-vibrant-200/80 text-lg max-w-2xl">{data.subtitle}</p>
    </div>
  </section>

  <!-- Resource Cards -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        {data.cards.map((card: any) => (
          <a href={card.external ? card.url : `${base}${card.url.replace(/^\//, '')}`} target={card.external ? '_blank' : undefined} rel={card.external ? 'noopener noreferrer' : undefined} class="group block bg-white rounded-xl border border-gray-200 hover:border-vibrant-300 hover:shadow-xl transition-all duration-200 overflow-hidden">
            <div class="p-8">
              <div class={`w-12 h-12 rounded-xl ${card.icon_bg} flex items-center justify-center mb-5`}>
                {card.icon_fill ? (
                  <svg class={`w-6 h-6 ${card.icon_color}`} viewBox={card.icon_svg_viewbox || '0 0 24 24'} fill="currentColor">
                    <Fragment set:html={card.icon_svg} />
                  </svg>
                ) : (
                  <svg class={`w-6 h-6 ${card.icon_color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <Fragment set:html={card.icon_svg} />
                  </svg>
                )}
              </div>
              <h2 class="text-xl font-bold font-display text-neutral-stone mb-3 group-hover:text-vibrant-600 transition-colors">{card.title}</h2>
              <p class="text-gray-600 leading-relaxed mb-6">{card.description}</p>
              <span class="inline-flex items-center gap-2 text-vibrant-600 font-medium text-sm group-hover:gap-3 transition-all">
                {card.link_text}
                {card.external ? (
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                ) : (
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                )}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
