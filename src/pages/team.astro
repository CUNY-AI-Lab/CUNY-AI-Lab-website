---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;
const jsonPath = path.join(process.cwd(), 'src/data/team.json');
const data = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));
---

<BaseLayout title="Team - CUNY AI Lab">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-10 lg:pt-28 lg:pb-12">
    <div class="absolute inset-0 bg-gradient-to-b from-cuny-blue via-cuny-blue to-vibrant-900"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"1\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-white tracking-tight">{data.title}</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg text-gray-600 leading-relaxed">
        {data.intro}
      </p>
    </div>
  </section>

  <!-- Leadership Section -->
  <section class="py-16 bg-neutral-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-display text-neutral-stone mb-8">Leadership</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 justify-items-center">
        {data.leadership.map((member: any) => (
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden w-full max-w-[280px] group border border-gray-100">
            <div class="aspect-[3/4] overflow-hidden bg-gray-100 relative">
              <img src={`${base}${member.photo}`} alt={member.name} class={`w-full h-full object-cover object-${member.photo_position} group-hover:scale-105 transition-transform duration-500`} />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            <div class="p-5">
              <h3 class="text-lg font-bold font-display text-neutral-stone mb-1">{member.name}</h3>
              <p class="text-vibrant-600 font-semibold mb-3 text-sm uppercase tracking-wide">{member.title}</p>
              <p class="text-gray-600 text-sm leading-relaxed">
                {member.subtitle}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Fellows Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-display text-neutral-stone mb-8">Fellows</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 justify-items-center">
        {data.fellows.map((fellow: any) => (
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden w-full max-w-[280px] group border border-gray-100">
            <div class={`aspect-[3/4] overflow-hidden ${fellow.photo_bg || 'bg-gray-100'} relative${fellow.photo_bg ? ' flex items-center justify-center' : ''}`}>
              <img src={`${base}${fellow.photo}`} alt={fellow.name} class={`w-full h-full object-cover${fellow.photo_bg ? '' : ` object-${fellow.photo_position} group-hover:scale-105 transition-transform duration-500`}`} />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            <div class="p-5">
              <h3 class="text-lg font-bold font-display text-neutral-stone mb-1">{fellow.name}</h3>

            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Collaborating Units -->
  <section class="py-16 bg-neutral-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-display text-neutral-stone mb-8">Collaborating Units</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {data.partners.map((partner: any) => (
          <a href={partner.url} target="_blank" rel="noopener noreferrer" class={`flex items-center justify-center ${partner.bg_class || 'bg-white'} p-3 rounded-lg border border-gray-200 hover:border-vibrant-300 hover:shadow-md transition-all group`}>
            <img src={`${base}${partner.logo}`} alt={partner.name} class="h-20 w-auto object-contain group-hover:scale-105 transition-transform" />
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
