---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;
const jsonPath = path.join(process.cwd(), 'src/data/events.json');
const data = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));
---

<BaseLayout title="Events - CUNY AI Lab">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-10 lg:pt-28 lg:pb-12">
    <div class="absolute inset-0 bg-gradient-to-b from-cuny-blue via-cuny-blue to-vibrant-900"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-white tracking-tight">{data.title}</h1>
      <p class="mt-4 text-vibrant-200/80 text-lg max-w-2xl">{data.subtitle}</p>
    </div>
  </section>

  <!-- Section Nav -->
  <nav class="bg-white border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-center gap-6 py-4">
      <a href="#workshops" class="text-sm font-semibold text-vibrant-600 hover:text-vibrant-700 transition-colors">Workshop Series</a>
      <a href="#coworking" class="text-sm font-semibold text-vibrant-600 hover:text-vibrant-700 transition-colors">Co-Working Sessions</a>
    </div>
  </nav>

  <!-- Workshop Series -->
  <section id="workshops" class="py-16 bg-white scroll-mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold font-display text-neutral-stone mb-4">{data.series_title}</h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-10">
        {data.series_description}
      </p>

      <!-- Info callout -->
      <div class="bg-vibrant-50 border border-vibrant-200 rounded-2xl p-6 md:p-8 mb-12">
        <h3 class="text-sm font-bold text-vibrant-900 uppercase tracking-wide mb-4 flex items-center">
          <svg class="w-5 h-5 mr-2 text-vibrant-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Before You Register
        </h3>
        <ul class="space-y-3">
          {data.prerequisites.map((item: string) => (
            <li class="flex items-start">
              <span class="w-2 h-2 bg-vibrant-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <span class="text-gray-700" set:html={item} />
            </li>
          ))}
        </ul>
      </div>

      <!-- Workshop cards -->
      <div class="space-y-8">
        {data.workshops.map((workshop: any) => (
          <div class="relative bg-white rounded-2xl border border-gray-200 p-6 md:p-8 overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-vibrant-600 rounded-l-2xl"></div>
            <div class="flex flex-col md:flex-row md:items-start gap-5">
              <div class="flex-shrink-0">
                <div class="inline-flex items-center gap-2 bg-vibrant-50 text-vibrant-700 text-sm font-semibold px-4 py-2 rounded-full">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  {workshop.date}
                </div>
              </div>
              <div>
                <h3 class="text-xl font-bold font-display text-neutral-stone mb-2">{workshop.title}</h3>
                <p class={`text-gray-600 leading-relaxed${workshop.prerequisite ? ' mb-3' : ''}`}>
                  {workshop.description}
                </p>
                {workshop.prerequisite && (
                  <p class="text-sm text-gray-500 italic">
                    {workshop.prerequisite}
                  </p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Registration CTA -->
  <section class="py-16 bg-neutral-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h3 class="text-2xl font-bold font-display text-neutral-stone mb-4">{data.registration.heading}</h3>
      <p class="text-gray-600 mb-8">{data.registration.description}</p>
      <a
        href={data.registration.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-vibrant-600 text-white rounded-full font-bold text-lg hover:bg-vibrant-700 transition-colors shadow-lg hover:shadow-vibrant-500/30"
      >
        {data.registration.button_text}
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Co-Working Sessions -->
  <section id="coworking" class="py-16 bg-white scroll-mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold font-display text-neutral-stone mb-4">{data.coworking_title}</h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-10">
        {data.coworking_description}
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        {data.coworking_sessions.map((session: any) => (
          <div class="relative bg-white rounded-2xl border border-gray-200 p-6 overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-vibrant-600 rounded-l-2xl"></div>
            <div class="flex items-center gap-2 mb-3">
              <svg class="w-4 h-4 text-vibrant-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="text-sm font-semibold text-vibrant-700">{session.date}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class={`inline-flex items-center gap-1.5 text-sm font-medium px-3 py-1 rounded-full ${session.format === 'Online' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700'}`}>
                {session.format === 'Online' ? (
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                ) : (
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                )}
                {session.format}
              </span>
              {session.location && (
                <span class="text-sm text-gray-500">{session.location}</span>
              )}
            </div>
            {session.registration_url && (
              <a
                href={session.registration_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold text-vibrant-600 hover:text-vibrant-700 transition-colors"
              >
                Register
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
