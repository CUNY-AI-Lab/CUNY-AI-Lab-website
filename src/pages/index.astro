---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;
const jsonPath = path.join(process.cwd(), 'src/data/homepage.json');
const data = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));
---

<BaseLayout title="CUNY AI Lab">
  <!-- Hero -->
  <section class="relative flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-neutral-cream via-white to-neutral-cream"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-vibrant-50/50 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-cuny-blue/5 rounded-full blur-3xl -translate-x-1/2 translate-y-1/2"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-20 w-full">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <p class="text-vibrant-600 font-medium tracking-wide uppercase text-sm mb-6">
            {data.tagline}
          </p>

          <h1 class="text-5xl sm:text-6xl lg:text-6xl font-bold font-display text-neutral-stone leading-[1.1] mb-8">
            {data.title}
          </h1>

          <p class="text-xl text-gray-600 leading-relaxed mb-10">
            {data.description}
          </p>

          <div class="flex flex-wrap gap-4 items-center">
            <a href={`${base}about`} class="px-7 py-3 bg-vibrant-600 text-white rounded-full font-medium hover:bg-vibrant-700 transition-colors">
              {data.cta_primary.text}
            </a>
            <a href={`${base}tools`} class="text-vibrant-600 font-medium hover:text-vibrant-700 transition-colors">
              {data.cta_secondary.text} &rarr;
            </a>
          </div>
        </div>

        <!-- Guiding Principles -->
        <div class="lg:col-span-5">
          <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-gray-100">
            <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-6">{data.principles_heading}</h2>
            <div class="space-y-5">
              {data.principles.map((principle: any) => (
                <div class="flex items-start gap-4">
                  <div class={`w-10 h-10 rounded-xl ${principle.icon_bg} flex items-center justify-center flex-shrink-0`}>
                    <svg class={`w-5 h-5 ${principle.icon_color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <Fragment set:html={principle.icon_svg} />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-neutral-stone">{principle.title}</h3>
                    <p class="text-gray-600 text-sm mt-1">{principle.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* Homepage: make main a flex column so the hero absorbs extra viewport height */
  body:has(> main > section:only-child) > main {
    display: flex;
    flex-direction: column;
  }
  body:has(> main > section:only-child) > main > section {
    flex: 1;
  }
</style>
