---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;
const jsonPath = path.join(process.cwd(), 'src/data/tools.json');
const data = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));
---

<BaseLayout title="Tools - CUNY AI Lab">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-10 lg:pt-28 lg:pb-12">
    <div class="absolute inset-0 bg-gradient-to-b from-cuny-blue via-cuny-blue to-vibrant-900"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-white tracking-tight">{data.title}</h1>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SECTION A: OpenWebUI Ecosystem             -->
  <!-- ═══════════════════════════════════════════ -->

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- CAIL Sandbox Hero -->
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <!-- Left: Screenshot + Feature badges -->
        <div>
          <div class="relative">
            <div class="rounded-2xl overflow-hidden shadow-2xl border border-gray-200">
              <img src={`${base}${data.sandbox.screenshot}`} alt={data.sandbox.screenshot_alt} class="w-full h-auto" />
            </div>
            <!-- Decorative glow -->
            <div class="absolute -inset-4 bg-gradient-to-br from-vibrant-400/10 to-cuny-blue/10 rounded-3xl -z-10 blur-2xl"></div>
          </div>

          <!-- Feature badges -->
          <div class="mt-8 space-y-3">
            {data.sandbox.features.map((feature: any) => (
              <div class="flex items-start gap-3">
                <div class="w-2 h-2 rounded-full bg-vibrant-600 mt-2 flex-shrink-0"></div>
                <div>
                  <span class="font-semibold text-neutral-stone text-sm">{feature.label}</span>
                  <span class="text-gray-500 text-sm ml-1">— {feature.detail}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Content -->
        <div>
          <h2 class="text-3xl font-bold font-display text-neutral-stone mb-6">{data.sandbox.heading}</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed" set:html={data.sandbox.description_html} />

          <div class="mt-8 flex flex-wrap gap-4">
            <a href={data.sandbox.launch_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-vibrant-600 text-white rounded-full font-medium hover:bg-vibrant-700 transition-colors shadow-md">
              Launch CAIL Sandbox
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href={`${base}models`} class="inline-flex items-center gap-2 px-6 py-3 border border-gray-300 text-neutral-stone rounded-full font-medium hover:border-vibrant-300 hover:text-vibrant-600 transition-colors">
              View Model Registry
            </a>
          </div>
        </div>
      </div>

      <!-- Classroom Chatbots — part of the OWU ecosystem -->
      <div class="mt-20 pt-16 border-t border-gray-200">
        <h3 class="text-2xl font-bold font-display text-neutral-stone mb-2">{data.chatbots.heading}</h3>
        <p class="text-gray-500 mb-8">{data.chatbots.subtitle}</p>

        <div class="grid md:grid-cols-3 gap-6">
          {data.chatbots.items.map((chatbot: any) => (
            <div class="bg-neutral-cream rounded-xl p-6 border border-gray-100 hover:shadow-lg transition-all">
              <div class={`w-10 h-10 rounded-lg ${chatbot.icon_bg} flex items-center justify-center mb-4`}>
                <svg class={`w-5 h-5 ${chatbot.icon_color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <Fragment set:html={chatbot.icon_svg} />
                </svg>
              </div>
              <h4 class="font-bold text-neutral-stone mb-2">{chatbot.title}</h4>
              <p class={`text-gray-600 text-sm${chatbot.examples ? ' mb-3' : ''}`}>{chatbot.description}</p>
              {chatbot.examples && (
                <p class="text-xs text-gray-400">{chatbot.examples}</p>
              )}
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SECTION B: Standalone Tools Portal          -->
  <!-- ═══════════════════════════════════════════ -->

  <section class="py-16 bg-neutral-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Portal header -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-4">
        <div>
          <h2 class="text-3xl font-bold font-display text-neutral-stone">{data.portal.heading}</h2>
        </div>
        <a href={data.portal.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-vibrant-600 text-white rounded-full font-medium hover:bg-vibrant-700 transition-colors flex-shrink-0">
          Visit Portal
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
      </div>
      <p class="text-gray-600 mb-12 max-w-3xl">{data.portal.description}</p>

      <!-- Media Processing subsection -->
      <div class="mb-16">
        <h3 class="text-2xl font-bold font-display text-neutral-stone mb-2">{data.media_processing.heading}</h3>
        <p class="text-gray-500 mb-2">{data.media_processing.subtitle}</p>
        <p class="text-sm text-gray-400 mb-8">{data.media_processing.sensitive_data_note} <a href={`${base}contact`} class="text-vibrant-600 hover:underline">Contact us</a>.</p>

        <!-- Tool selector buttons -->
        <div class="grid md:grid-cols-3 gap-6 mb-8">
          {data.media_processing.tools.map((tool: any, i: number) => (
            <a href={tool.url} target="_blank" rel="noopener noreferrer" class={`media-tool-btn block bg-white rounded-xl p-5 border-2 ${i === 0 ? 'border-vibrant-300' : 'border-transparent'} transition-all hover:shadow-lg ${i === 0 ? '' : 'hover:border-gray-200'} group`} data-slide={i}>
              <div class="flex items-start justify-between gap-2">
                <h4 class="font-bold text-neutral-stone mb-1">{tool.title}</h4>
                <svg class="w-4 h-4 text-gray-400 group-hover:text-vibrant-600 transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </div>
              <p class="text-gray-600 text-sm">{tool.description}</p>
            </a>
          ))}
        </div>

        <!-- Screenshot Slider -->
        <div class="relative mb-4">
          <div id="media-slider" class="relative rounded-2xl overflow-hidden shadow-xl border border-gray-200 bg-gray-50">
            <div class="relative aspect-[16/10] sm:aspect-[16/9] md:aspect-[16/8]">
              {data.media_processing.tools.map((tool: any, i: number) => (
                <img id={`slide-${i}`} src={`${base}${tool.screenshot}`} alt={tool.screenshot_alt} class={`absolute inset-0 w-full h-full object-contain object-top bg-white transition-opacity duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0'}`} />
              ))}
            </div>
          </div>

          <!-- Slider controls -->
          <button id="slider-prev" class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/90 shadow-lg border border-gray-200 flex items-center justify-center hover:bg-white transition-colors z-10">
            <svg class="w-5 h-5 text-neutral-stone" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button id="slider-next" class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/90 shadow-lg border border-gray-200 flex items-center justify-center hover:bg-white transition-colors z-10">
            <svg class="w-5 h-5 text-neutral-stone" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </button>

          <!-- Dots -->
          <div class="flex justify-center gap-2 mt-4">
            {data.media_processing.tools.map((_: any, i: number) => (
              <button class={`slider-dot w-2.5 h-2.5 rounded-full ${i === 0 ? 'bg-vibrant-600' : 'bg-gray-300'} transition-colors`} data-slide={i}></button>
            ))}
          </div>
        </div>
      </div>

      <!-- AI Assistants subsection -->
      <div class="pt-12 border-t border-gray-200">
        <h3 class="text-2xl font-bold font-display text-neutral-stone mb-2">{data.ai_assistants.heading}</h3>
        <p class="text-gray-500 mb-8">{data.ai_assistants.subtitle}</p>

        <div class="grid md:grid-cols-2 gap-8">
          {data.ai_assistants.tools.map((tool: any) => (
            <a href={tool.url} target="_blank" rel="noopener noreferrer" class="block bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg hover:border-vibrant-200 transition-all group">
              <div class="p-6">
                <div class={`w-10 h-10 rounded-lg ${tool.icon_bg} flex items-center justify-center mb-4`}>
                  <svg class={`w-5 h-5 ${tool.icon_color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <Fragment set:html={tool.icon_svg} />
                  </svg>
                </div>
                <div class="flex items-start justify-between gap-2">
                  <h4 class="text-lg font-bold text-neutral-stone mb-2">{tool.title}</h4>
                  <svg class="w-4 h-4 text-gray-400 group-hover:text-vibrant-600 transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </div>
                <p class="text-gray-600 text-sm leading-relaxed">{tool.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

  <script is:inline>
    (function() {
      var current = 0;
      var total = 3;
      var slides = [document.getElementById('slide-0'), document.getElementById('slide-1'), document.getElementById('slide-2')];
      var dots = document.querySelectorAll('.slider-dot');
      var toolBtns = document.querySelectorAll('.media-tool-btn');

      function goTo(index) {
        slides[current].style.opacity = '0';
        dots[current].className = 'slider-dot w-2.5 h-2.5 rounded-full bg-gray-300 transition-colors';
        toolBtns[current].className = 'media-tool-btn block bg-white rounded-xl p-5 border-2 border-transparent transition-all hover:shadow-lg hover:border-gray-200 group';

        current = (index + total) % total;

        slides[current].style.opacity = '1';
        dots[current].className = 'slider-dot w-2.5 h-2.5 rounded-full bg-vibrant-600 transition-colors';
        toolBtns[current].className = 'media-tool-btn block bg-white rounded-xl p-5 border-2 border-vibrant-300 transition-all hover:shadow-lg group';
      }

      document.getElementById('slider-prev').addEventListener('click', function() { goTo(current - 1); });
      document.getElementById('slider-next').addEventListener('click', function() { goTo(current + 1); });

      dots.forEach(function(dot) {
        dot.addEventListener('click', function() { goTo(parseInt(this.dataset.slide)); });
      });

      toolBtns.forEach(function(btn) {
        btn.addEventListener('mouseenter', function() { goTo(parseInt(this.dataset.slide)); });
      });
    })();
  </script>

</BaseLayout>
