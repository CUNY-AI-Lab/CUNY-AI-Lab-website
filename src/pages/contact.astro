---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL;
const entry = await getEntry('pages', 'contact');
const data = entry.data;
const { Content } = await entry.render();
---

<BaseLayout title="Contact - CUNY AI Lab">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-10 lg:pt-28 lg:pb-12">
    <div class="absolute inset-0 bg-gradient-to-b from-cuny-blue via-cuny-blue to-vibrant-900"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-white tracking-tight">{data.title}</h1>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Intro -->
      <div class="contact-intro mb-12">
        <Content />
      </div>

      <!-- Email card -->
      <div class="relative bg-gradient-to-br from-neutral-cream to-white rounded-3xl p-10 md:p-14 border border-gray-100 shadow-sm overflow-hidden group">
        <!-- Decorative element -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-vibrant-100/50 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>

        <div class="relative">
          <p class="text-sm font-semibold text-vibrant-600 uppercase tracking-widest mb-6">{data.email_label}</p>

          <a
            href={`mailto:${data.email}`}
            class="inline-flex items-center text-3xl sm:text-4xl md:text-5xl font-bold font-display text-neutral-stone hover:text-vibrant-600 transition-colors duration-300 tracking-tight"
          >
            {data.email}
            <svg class="w-8 h-8 md:w-10 md:h-10 ml-4 transform group-hover:translate-x-2 transition-transform duration-300 text-vibrant-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>

          <div class="mt-10 pt-8 border-t border-gray-200">
            <p class="text-gray-500 leading-relaxed max-w-xl">{data.card_detail}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Forms Section -->
  <section class="py-16 bg-neutral-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-display text-neutral-stone mb-8">Forms</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <a href="https://docs.google.com/forms/d/e/1FAIpQLScf2_xvqB-BG9L1hFjwm8-MJfoZ9zCw7cj3cYAUiYodaedu2A/viewform" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-xl border border-gray-200 hover:border-vibrant-300 hover:shadow-lg transition-all duration-200 p-6">
          <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
          </div>
          <h3 class="text-base font-bold font-display text-neutral-stone mb-2 group-hover:text-vibrant-600 transition-colors">Sandbox Access</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Apply for access to the CAIL Sandbox.</p>
        </a>

        <a href="https://docs.google.com/forms/d/e/1FAIpQLSfgrqqPunSrRiIwFhfO23b84_JDbu4HlV6Cvgx1PqtshsS7Xw/viewform" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-xl border border-gray-200 hover:border-vibrant-300 hover:shadow-lg transition-all duration-200 p-6">
          <div class="w-10 h-10 rounded-lg bg-vibrant-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-vibrant-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
            </svg>
          </div>
          <h3 class="text-base font-bold font-display text-neutral-stone mb-2 group-hover:text-vibrant-600 transition-colors">Consultation Request</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Request a consultation with the CUNY AI Lab.</p>
        </a>

        <a href="https://docs.google.com/forms/d/e/1FAIpQLSfGHEgp-x59DsUDQtqgjcHNdBBuhmT131DFuFdOXfOYyrNKyg/viewform" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-xl border border-gray-200 hover:border-vibrant-300 hover:shadow-lg transition-all duration-200 p-6">
          <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
          </div>
          <h3 class="text-base font-bold font-display text-neutral-stone mb-2 group-hover:text-vibrant-600 transition-colors">Bug Report</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Report an issue with the CAIL Sandbox or tools.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .contact-intro p {
    font-family: Inter, system-ui, sans-serif;
    font-size: 1.25rem;
    line-height: 1.625;
    color: #4b5563;
  }
  @media (min-width: 768px) {
    .contact-intro p {
      font-size: 1.5rem;
    }
  }
</style>
