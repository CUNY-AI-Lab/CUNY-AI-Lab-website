---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL;
const entry = await getEntry('pages', 'about');
const data = entry.data;
const { Content } = await entry.render();
---

<BaseLayout title="About - CUNY AI Lab">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-10 lg:pt-28 lg:pb-12">
    <div class="absolute inset-0 bg-gradient-to-b from-cuny-blue via-cuny-blue to-vibrant-900"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-white tracking-tight">{data.title}</h1>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">
        <!-- Main content -->
        <div class="lg:col-span-2">
          <div class="about-content">
            <Content />
          </div>
        </div>

        <!-- Principles sidebar -->
        <div class="lg:col-span-1">
          <div class="bg-neutral-cream rounded-2xl p-6 border border-gray-100">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-5">Guiding Principles</h3>
            <ul class="space-y-4">
              {data.principles.map((principle: any) => (
                <li>
                  <h4 class="font-semibold text-neutral-stone">{principle.title}</h4>
                  <p class="text-sm text-gray-500 mt-1">{principle.description}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-neutral-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold font-display text-neutral-stone mb-6">
        {data.cta.heading}
      </h2>
      <p class="text-lg text-gray-600 mb-10 max-w-2xl mx-auto">
        {data.cta.description}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}contact`} class="inline-block bg-vibrant-600 text-white px-8 py-4 rounded-full font-semibold hover:bg-vibrant-700 transition-all shadow-lg hover:shadow-vibrant-500/30 transform hover:-translate-y-1">
          {data.cta.primary.text}
        </a>
        <a href={`${base}tools`} class="inline-block bg-white text-vibrant-600 border-2 border-vibrant-600 px-8 py-4 rounded-full font-semibold hover:bg-vibrant-50 transition-colors">
          {data.cta.secondary.text}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .about-content p {
    color: #4b5563;
    font-size: 1.125rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }
  .about-content p:last-child {
    margin-bottom: 0;
  }
  .about-content a {
    color: #3B73E6;
    text-decoration: underline;
  }
  .about-content a:hover {
    color: #2A6FB8;
  }
</style>
