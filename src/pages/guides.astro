---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Guides & Tutorials - CUNY AI Lab">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-10 lg:pt-28 lg:pb-12">
    <div class="absolute inset-0 bg-gradient-to-b from-cuny-blue via-cuny-blue to-vibrant-900"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-white tracking-tight">Guides & Tutorials</h1>
      <p class="mt-4 text-vibrant-200/80 text-lg max-w-2xl">Slide decks, written guides, and workshop materials produced by the CUNY AI Lab. These resources are designed to be used independently or alongside our <a href={`${base}events`} class="text-white underline hover:text-vibrant-100">workshops and events</a>.</p>
    </div>
  </section>

  <!-- AI-Assisted Development Guide (standalone) -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="https://cuny-ai-lab.github.io/vibe-coding-how-to/" target="_blank" rel="noopener noreferrer" class="group block bg-gradient-to-br from-indigo-50 to-vibrant-50 rounded-2xl border border-indigo-200 hover:border-vibrant-400 hover:shadow-xl transition-all p-8 md:p-10">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="w-14 h-14 rounded-xl bg-indigo-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div class="flex-1">
            <h2 class="text-2xl font-bold font-display text-neutral-stone mb-2 group-hover:text-vibrant-600 transition-colors">AI-Assisted Development Guide</h2>
            <p class="text-gray-600 leading-relaxed">A step-by-step written tutorial on building digital projects with AI coding assistants. Covers environment setup, prompting strategies, and project workflows for beginners.</p>
          </div>
          <div class="flex-shrink-0">
            <span class="inline-flex items-center gap-2 text-vibrant-600 font-semibold text-sm group-hover:gap-3 transition-all">
              Read the guide
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Workshop Slide Decks -->
  <section class="py-16 bg-neutral-cream">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold font-display text-neutral-stone mb-3">Workshop Slide Decks</h2>
      <p class="text-gray-600 leading-relaxed mb-10 max-w-3xl">Slides from our workshop series, available for independent review or reuse. Each deck is a self-contained Reveal.js presentation that can be navigated in the browser.</p>

      <!-- Vibe Coding Workshop Series -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg bg-vibrant-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-vibrant-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold font-display text-neutral-stone">Vibe Coding Workshop Series</h3>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <a href="https://cuny-ai-lab.github.io/gen-dev-foundations/" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-xl border border-gray-200 hover:border-vibrant-300 hover:shadow-lg transition-all p-6">
            <div class="flex items-start justify-between gap-3 mb-3">
              <span class="inline-flex items-center px-2.5 py-0.5 bg-vibrant-50 text-vibrant-700 text-xs font-medium rounded-full">Part 1</span>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-vibrant-600 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </div>
            <h4 class="text-lg font-bold text-neutral-stone mb-2 group-hover:text-vibrant-600 transition-colors">Foundations: AI, Command Line, and Version Control</h4>
            <p class="text-gray-600 text-sm leading-relaxed">Core concepts for AI-assisted development, including environment setup, terminal basics, and Git workflows.</p>
          </a>
          <a href="https://cuny-ai-lab.github.io/vibe-coding-prototypes" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-xl border border-gray-200 hover:border-vibrant-300 hover:shadow-lg transition-all p-6">
            <div class="flex items-start justify-between gap-3 mb-3">
              <span class="inline-flex items-center px-2.5 py-0.5 bg-vibrant-50 text-vibrant-700 text-xs font-medium rounded-full">Part 2</span>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-vibrant-600 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </div>
            <h4 class="text-lg font-bold text-neutral-stone mb-2 group-hover:text-vibrant-600 transition-colors">Vibe-Coding Prototypes</h4>
            <p class="text-gray-600 text-sm leading-relaxed">Building prototypes with AI coding assistants, including prompting strategies, project design, and troubleshooting.</p>
          </a>
        </div>
      </div>

      <!-- Using the CAIL Sandbox in the Classroom -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-neutral-stone">Using the CAIL Sandbox in the Classroom</h3>
            <p class="text-sm text-gray-500 mt-0.5">Three-part series (more coming soon)</p>
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <a href="https://cuny-ai-lab.github.io/system-prompting/" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-xl border border-gray-200 hover:border-amber-300 hover:shadow-lg transition-all p-6">
            <div class="flex items-start justify-between gap-3 mb-3">
              <span class="inline-flex items-center px-2.5 py-0.5 bg-amber-50 text-amber-700 text-xs font-medium rounded-full">Part 1</span>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-amber-600 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </div>
            <h4 class="text-lg font-bold text-neutral-stone mb-2 group-hover:text-amber-600 transition-colors">System Prompting</h4>
            <p class="text-gray-600 text-sm leading-relaxed">How to craft effective system prompts to shape AI behavior for classroom use cases and custom assistants.</p>
          </a>
          <div class="flex items-center justify-center bg-white/50 rounded-xl border border-dashed border-gray-300 p-6">
            <p class="text-gray-400 text-sm text-center">Parts 2 and 3 coming soon</p>
          </div>
        </div>
      </div>

      <!-- Standalone -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-8 rounded-lg bg-teal-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold font-display text-neutral-stone">Standalone</h3>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <a href="https://cuny-ai-lab.github.io/creative-coding" target="_blank" rel="noopener noreferrer" class="group block bg-white rounded-xl border border-gray-200 hover:border-teal-300 hover:shadow-lg transition-all p-6">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h4 class="text-lg font-bold text-neutral-stone group-hover:text-teal-600 transition-colors">Creative Coding</h4>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-teal-600 transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed">An introduction to creative coding with AI, exploring generative art and creative applications of programming.</p>
          </a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
