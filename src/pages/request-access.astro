---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;
const jsonPath = path.join(process.cwd(), 'src/data/request-access.json');
const data = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));
---

<BaseLayout title="Request Access - CUNY AI Lab">
  <!-- Hero Section -->
  <section class="relative pt-24 pb-10 lg:pt-28 lg:pb-12">
    <div class="absolute inset-0 bg-gradient-to-b from-cuny-blue via-cuny-blue to-vibrant-900"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"1\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-white tracking-tight">{data.title}</h1>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Introduction -->
      <div class="mb-16 text-center">
        <h2 class="text-3xl font-bold font-display text-neutral-stone mb-6">{data.intro_heading}</h2>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          {data.intro_description}
        </p>
        <div class="bg-vibrant-50 border border-vibrant-200 rounded-2xl p-8 text-left shadow-sm">
          <h3 class="text-lg font-bold text-vibrant-900 mb-4 flex items-center">
            <svg class="w-6 h-6 mr-2 text-vibrant-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {data.features_heading}
          </h3>
          <ul class="space-y-3">
            {data.features.map((feature: string) => (
              <li class="flex items-start">
                <span class="w-2 h-2 bg-vibrant-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Access Request Form -->
      <div class="bg-white border border-gray-200 rounded-2xl p-8 md:p-10 shadow-lg relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-vibrant-400 to-cuny-blue"></div>
        <h3 class="text-2xl font-bold font-display text-neutral-stone mb-8">{data.form_heading}</h3>

        <form action={data.form_action} method="POST" class="space-y-6">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">
              {data.form_fields.name.label} <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-vibrant-500 focus:border-vibrant-500 transition-all bg-gray-50 focus:bg-white"
              placeholder={data.form_fields.name.placeholder}
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
              {data.form_fields.email.label} <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-vibrant-500 focus:border-vibrant-500 transition-all bg-gray-50 focus:bg-white"
              placeholder={data.form_fields.email.placeholder}
            />
          </div>

          <!-- CUNY Affiliation -->
          <div>
            <label for="affiliation" class="block text-sm font-semibold text-gray-700 mb-2">
              {data.form_fields.affiliation.label} <span class="text-red-500">*</span>
            </label>
            <select
              id="affiliation"
              name="affiliation"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-vibrant-500 focus:border-vibrant-500 transition-all bg-gray-50 focus:bg-white"
            >
              {data.form_fields.affiliation.options.map((option: any) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </div>

          <!-- Department/Program -->
          <div>
            <label for="department" class="block text-sm font-semibold text-gray-700 mb-2">
              {data.form_fields.department.label} <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="department"
              name="department"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-vibrant-500 focus:border-vibrant-500 transition-all bg-gray-50 focus:bg-white"
              placeholder={data.form_fields.department.placeholder}
            />
          </div>

          <!-- College/Campus -->
          <div>
            <label for="campus" class="block text-sm font-semibold text-gray-700 mb-2">
              {data.form_fields.campus.label} <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="campus"
              name="campus"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-vibrant-500 focus:border-vibrant-500 transition-all bg-gray-50 focus:bg-white"
              placeholder={data.form_fields.campus.placeholder}
            />
          </div>

          <!-- Intended Use -->
          <div>
            <label for="intended-use" class="block text-sm font-semibold text-gray-700 mb-2">
              {data.form_fields.intended_use.label} <span class="text-red-500">*</span>
            </label>
            <textarea
              id="intended-use"
              name="intended-use"
              required
              rows="4"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-vibrant-500 focus:border-vibrant-500 transition-all bg-gray-50 focus:bg-white"
              placeholder={data.form_fields.intended_use.placeholder}
            ></textarea>
          </div>

          <!-- Specific Tools -->
          <div>
            <label for="tools-of-interest" class="block text-sm font-semibold text-gray-700 mb-3">
              {data.tools_of_interest.label}
            </label>
            <div class="space-y-3 bg-gray-50 p-4 rounded-lg border border-gray-200">
              {data.tools_of_interest.options.map((tool: any) => (
                <label class="flex items-center cursor-pointer hover:bg-gray-100 p-2 rounded transition-colors">
                  <input type="checkbox" name="tools[]" value={tool.value} class="w-5 h-5 text-vibrant-600 rounded focus:ring-vibrant-500 border-gray-300 mr-3" />
                  <span class="text-gray-700">{tool.label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Submit Button -->
          <div class="pt-6">
            <button
              type="submit"
              class="w-full bg-vibrant-600 text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-vibrant-700 transition-all shadow-lg hover:shadow-vibrant-500/30 transform hover:-translate-y-1"
            >
              {data.submit_text}
            </button>
          </div>

          <!-- Privacy Note -->
          <p class="text-xs text-gray-500 mt-6 text-center">
            {data.privacy_note}
          </p>
        </form>
      </div>

      <!-- What Happens Next -->
      <div class="mt-16 bg-neutral-cream p-8 rounded-2xl border border-gray-100">
        <h3 class="text-xl font-bold font-display text-neutral-stone mb-6">{data.next_steps_heading}</h3>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          {data.next_steps.map((step: any) => (
            <div class="relative">
              <div class="w-10 h-10 rounded-full bg-vibrant-100 text-vibrant-600 flex items-center justify-center font-bold mb-3">{step.step}</div>
              <h4 class="font-bold text-gray-900 mb-1">{step.title}</h4>
              {step.description_html ? (
                <p class="text-sm text-gray-600" set:html={step.description_html} />
              ) : (
                <p class="text-sm text-gray-600">{step.description}</p>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Questions -->
      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-4">
          {data.questions_text}
        </p>
        <a href={`${base}contact`} class="inline-block text-vibrant-600 hover:text-vibrant-800 font-semibold transition-colors">
          {data.questions_link_text}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
