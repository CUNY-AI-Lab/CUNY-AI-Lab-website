---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// Helper function to check if link is active
const isActive = (path: string) => {
  if (path === base && currentPath === base) return true;
  // "Resources" nav item also highlights on /models and /models/guide
  if (path === `${base}resources` && (currentPath.startsWith(`${base}models`) || currentPath.startsWith(`${base}resources`))) return true;
  if (path !== base && currentPath.startsWith(path.replace(base, base))) return true;
  return false;
};

const linkClass = (path: string) => {
  const baseClass = "px-4 py-2 rounded-full text-sm font-medium transition-all duration-200";
  return isActive(path)
    ? `${baseClass} bg-vibrant-50 text-vibrant-700 font-semibold shadow-sm ring-1 ring-vibrant-200`
    : `${baseClass} text-neutral-stone hover:text-vibrant-600 hover:bg-white/50`;
};

const mobileLinkClass = (path: string) => {
  const baseClass = "block px-4 py-3 rounded-lg text-base font-medium transition-colors";
  return isActive(path)
    ? `${baseClass} bg-vibrant-50 text-vibrant-700 font-semibold border-l-4 border-vibrant-500`
    : `${baseClass} text-neutral-stone hover:text-vibrant-600 hover:bg-gray-50`;
};

// "About" groups Team and Contact, so its trigger highlights on any of those pages
const isAboutSection = isActive(`${base}about`) || isActive(`${base}team`) || isActive(`${base}contact`);

const aboutTriggerClass = isAboutSection
  ? "bg-vibrant-50 text-vibrant-700 font-semibold shadow-sm ring-1 ring-vibrant-200"
  : "text-neutral-stone hover:text-vibrant-600 hover:bg-white/50";

const subItemClass = (path: string) =>
  isActive(path)
    ? "block px-4 py-2 text-sm font-semibold text-vibrant-700 bg-vibrant-50"
    : "block px-4 py-2 text-sm text-neutral-stone hover:text-vibrant-600 hover:bg-vibrant-50 transition-colors";
---

<header class="fixed w-full top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-200/80 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-[4.5rem]">
      <div class="flex-shrink-0">
        <a href={base} class="hover:opacity-80 transition-opacity">
          <img src={`${base}images/logo-horizontal.png`} alt="CUNY AI Lab" class="h-10 w-auto" />
        </a>
      </div>
      <div class="hidden lg:block">
        <div class="ml-10 flex items-baseline space-x-8">
          <a href={base} class={linkClass(base)}>
            Home
          </a>
          <div class="relative nav-dropdown" data-dropdown data-open="false">
            <div class={`flex items-center rounded-full text-sm font-medium transition-all duration-200 ${aboutTriggerClass}`}>
              <a href={`${base}about`} class="pl-4 pr-1.5 py-2 rounded-l-full focus:outline-none focus-visible:ring-2 focus-visible:ring-vibrant-400">
                About
              </a>
              <button
                type="button"
                data-dropdown-toggle
                aria-label="Show About submenu"
                aria-expanded="false"
                aria-controls="about-submenu"
                class="pr-3 pl-1 py-2 rounded-r-full focus:outline-none focus-visible:ring-2 focus-visible:ring-vibrant-400"
              >
                <svg class="nav-dropdown__chevron h-4 w-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            </div>
            <div id="about-submenu" data-dropdown-menu class="nav-dropdown__menu absolute left-0 top-full pt-2 min-w-[11rem] z-50">
              <div class="rounded-xl bg-white py-2 shadow-lg ring-1 ring-gray-200/80">
                <a href={`${base}team`} class={subItemClass(`${base}team`)}>Team</a>
                <a href={`${base}contact`} class={subItemClass(`${base}contact`)}>Contact</a>
              </div>
            </div>
          </div>
          <a href={`${base}tools`} class={linkClass(`${base}tools`)}>
            Tools
          </a>
          <!-- <a href={`${base}deploy`} class={linkClass(`${base}deploy`)}>
            🥬 Deploy
          </a> -->
          <a href={`${base}resources`} class={linkClass(`${base}resources`)}>
            Resources
          </a>
          <a href={`${base}blog`} class={linkClass(`${base}blog`)}>
            Blog
          </a>
          <a href="https://chat.ailab.gc.cuny.edu/" target="_blank" rel="noopener noreferrer" class="bg-vibrant-600 text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-vibrant-700 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
            CAIL Sandbox <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
      <div class="lg:hidden">
        <button id="mobile-menu-button" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu" class="text-neutral-stone hover:text-vibrant-600 focus:outline-none p-2 rounded-md hover:bg-vibrant-50 transition-colors">
          <svg class="h-6 w-6" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" role="navigation" aria-label="Mobile navigation" class="hidden lg:hidden bg-white/95 backdrop-blur-xl border-t border-gray-100 absolute w-full shadow-xl">
    <div class="px-4 pt-4 pb-6 space-y-2">
      <a href={base} class={mobileLinkClass(base)}>
        Home
      </a>
      <div class="flex items-center gap-1">
        <a href={`${base}about`} class={`${mobileLinkClass(`${base}about`)} flex-1`}>
          About
        </a>
        <button
          type="button"
          id="about-mobile-toggle"
          aria-label="Toggle About submenu"
          aria-expanded={isAboutSection ? "true" : "false"}
          aria-controls="about-mobile-submenu"
          class="p-3 rounded-lg text-neutral-stone hover:text-vibrant-600 hover:bg-gray-50 transition-colors"
        >
          <svg id="about-mobile-chevron" class={`h-5 w-5 transition-transform ${isAboutSection ? "rotate-180" : ""}`} aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>
      <div id="about-mobile-submenu" class={`${isAboutSection ? "" : "hidden"} pl-4 space-y-1 border-l-2 border-gray-100 ml-3`}>
        <a href={`${base}team`} class={mobileLinkClass(`${base}team`)}>
          Team
        </a>
        <a href={`${base}contact`} class={mobileLinkClass(`${base}contact`)}>
          Contact
        </a>
      </div>
      <a href={`${base}tools`} class={mobileLinkClass(`${base}tools`)}>
        Tools
      </a>
      <!-- <a href={`${base}deploy`} class={mobileLinkClass(`${base}deploy`)}>
        🥬 Deploy
      </a> -->
      <a href={`${base}resources`} class={mobileLinkClass(`${base}resources`)}>
        Resources
      </a>
      <a href={`${base}blog`} class={mobileLinkClass(`${base}blog`)}>
        Blog
      </a>
      <div class="pt-4 mt-4 border-t border-gray-100">
        <a href="https://chat.ailab.gc.cuny.edu/" target="_blank" rel="noopener noreferrer" class="block w-full text-center px-4 py-3 rounded-lg text-base font-semibold bg-vibrant-600 text-white hover:bg-vibrant-700 shadow-md">
          CAIL Sandbox <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenuButton?.setAttribute('aria-expanded', String(isOpen));
  });

  // Desktop "About" dropdown: hover and focus open it via CSS; the toggle button
  // and these handlers add click-to-open, click-outside/Escape-to-close, and keep
  // aria-expanded in sync for screen readers.
  document.querySelectorAll('[data-dropdown]').forEach((dropdown) => {
    const toggle = dropdown.querySelector('[data-dropdown-toggle]');
    if (!toggle) return;

    const setOpen = (open) => {
      dropdown.setAttribute('data-open', open ? 'true' : 'false');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    };

    toggle.addEventListener('click', (event) => {
      event.preventDefault();
      setOpen(dropdown.getAttribute('data-open') !== 'true');
    });

    // Tabbing into any control reflects the open state in aria-expanded
    dropdown.addEventListener('focusin', () => toggle.setAttribute('aria-expanded', 'true'));
    dropdown.addEventListener('focusout', (event) => {
      if (!dropdown.contains(event.relatedTarget)) setOpen(false);
    });

    dropdown.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setOpen(false);
        toggle.focus();
      }
    });

    document.addEventListener('click', (event) => {
      if (!dropdown.contains(event.target)) setOpen(false);
    });
  });

  // Mobile "About" accordion
  const aboutMobileToggle = document.getElementById('about-mobile-toggle');
  const aboutMobileSubmenu = document.getElementById('about-mobile-submenu');
  const aboutMobileChevron = document.getElementById('about-mobile-chevron');

  aboutMobileToggle?.addEventListener('click', () => {
    aboutMobileSubmenu?.classList.toggle('hidden');
    const isOpen = !aboutMobileSubmenu?.classList.contains('hidden');
    aboutMobileToggle.setAttribute('aria-expanded', String(isOpen));
    aboutMobileChevron?.classList.toggle('rotate-180', isOpen);
  });
</script>

<style>
  .nav-dropdown__menu {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
  }

  .nav-dropdown:hover > .nav-dropdown__menu,
  .nav-dropdown:focus-within > .nav-dropdown__menu,
  .nav-dropdown[data-open="true"] > .nav-dropdown__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown__chevron {
    transition: transform 0.15s ease;
  }

  .nav-dropdown:hover .nav-dropdown__chevron,
  .nav-dropdown:focus-within .nav-dropdown__chevron,
  .nav-dropdown[data-open="true"] .nav-dropdown__chevron {
    transform: rotate(180deg);
  }
</style>
